# Copy this file to `.env` (or `.env.local`) and fill in your values.
# All vars are EXPO_PUBLIC_* so Expo inlines them into the app at build time.
# Restart with `npx expo start -c` after changing them.
#
# These are all client-safe (public) values — the Supabase anon key is meant to
# be embedded in the app; Row-Level Security policies protect your data.

# Hosted courts.json the app fetches at launch (raw GitHub URL, GitHub Pages, or
# any CDN). Leave unset to use the bundled data only.
EXPO_PUBLIC_COURTS_URL=https://raw.githubusercontent.com/<your-username>/hoopmap/main/data/courts.json

# Supabase — enables shared, real-time crowd check-ins. Leave both unset to fall
# back to on-device (local) check-ins. Find these in your Supabase project under
# Settings → API (or the "Connect" button).
EXPO_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<your-anon-or-publishable-key>

# Sentry crash reporting (native builds only — web uses Vercel Analytics).
# Leave unset to disable entirely (lib/crash.js no-ops). From your Sentry
# project: Settings → Client Keys (DSN). DSNs are client-safe by design.
# EXPO_PUBLIC_SENTRY_DSN=https://<key>@<org-id>.ingest.us.sentry.io/<project-id>
#
# Set to 1 to surface the Settings → Developer "Send test crash report" button in
# a release build (e.g. a throwaway TestFlight build to verify Sentry). Leave
# UNSET for the App Store release so the button never ships to real users.
# EXPO_PUBLIC_SENTRY_TEST=1
